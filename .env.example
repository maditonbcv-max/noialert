# ===== Discord =====
# Bot トークン (Discord Developer Portal で発行)
DISCORD_TOKEN=
# 艦隊サーバー(ギルド)ID
DISCORD_GUILD_ID=
# 常時接続する警報用VCのチャンネルID
DISCORD_VOICE_CHANNEL_ID=
# 警報ログを投稿するテキストチャンネルID
DISCORD_LOG_CHANNEL_ID=

# ===== API 認証 (仕様 §10) =====
# 固定音声・定型TTS・ステータス用の共有シークレット
API_SECRET=change_me
# 自由入力TTS用の第2シークレット (管理者・警報係のみに配布)
TTS_API_SECRET=change_me_too

# ===== Web API =====
PORT=3000
# 発信用Webサイトのオリジン(CORS許可)。複数はカンマ区切り
ALLOWED_ORIGIN=https://alert.example.pages.dev

# ===== TTS エンジン (仕様 §7.3) =====
# openai | voicevox(将来)
TTS_ENGINE=openai
OPENAI_API_KEY=
# gpt-4o-mini-tts | tts-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OpenAI TTS の声 (alloy, echo, fable, onyx, nova, shimmer など)
OPENAI_TTS_VOICE=alloy
